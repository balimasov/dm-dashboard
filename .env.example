# DM password, gating the whole app (login page at /login) with full access
# to every block. If unset, the app runs with no login gate at all — fine
# for local dev, but set this before deploying anywhere reachable from the
# internet.
DASHBOARD_PASSWORD=

# Optional: a second, reduced-access password for players. Logging in with
# it hides the DM-only blocks (Campaign notes, Reminders, Enemies, NPCs,
# Settings) and shows everything else (Party, Companions, Party Toolkit,
# Inventory). Leave unset to disable player login entirely — only
# DASHBOARD_PASSWORD will work. Requires DASHBOARD_PASSWORD to also be set.
PLAYER_DASHBOARD_PASSWORD=

# Optional: where the SQLite database file lives. Defaults to `<working
# dir>/data`. Set this to your persistent volume's mount path in production
# (e.g. Railway) if it isn't mounted at `<working dir>/data` already —
# otherwise every redeploy wipes the database back to the demo characters.
DATA_DIR=
