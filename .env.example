# Shared password gating the whole app (login page at /login). If unset,
# the app runs with no login gate at all — fine for local dev, but set this
# before deploying anywhere reachable from the internet.
DASHBOARD_PASSWORD=

# Optional: where the SQLite database file lives. Defaults to `<working
# dir>/data`. Set this to your persistent volume's mount path in production
# (e.g. Railway) if it isn't mounted at `<working dir>/data` already —
# otherwise every redeploy wipes the database back to the demo characters.
DATA_DIR=
